# 默认忽略的文件
/shelf/
/workspace.xml
# 基于编辑器的 HTTP 客户端请求
/httpRequests/
# 依赖于环境的 Maven 主目录路径
/mavenHomeManager.xml
# Datasource local storage ignored files
/dataSources/
/dataSources.local.xml

# 依赖包
/node_modules

# 构建产物
/dist
/dist-ssr
*.local

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# IDEA 编辑器
.idea/
*.iml
*.iws
*.ipr

# VS Code（如果你偶尔用）
.vscode/*
!.vscode/extensions.json

# 系统文件
.DS_Store
Thumbs.db

# 环境变量（敏感信息）
.env
.env.local
.env.*.local